APP_NAME=金融知识问答助手
DATA_DIR=./storage
VECTOR_DB_PATH=./storage/vector_store.sqlite3
TOP_K=5
MIN_SCORE=0.35

# BGE-M3 is not included in this repository.
# Download it separately and set this path to your local model directory.
EMBEDDING_MODEL_PATH=D:\your-path\bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8
QUERY_INSTRUCTION=Represent this sentence for searching relevant passages: 

# Optional: OpenAI-compatible generation. Leave blank to use extractive grounded answers.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
